# Primary LLM endpoint (used by default / weak model)
BENCH_BASE_URL=http://your-server:8080/v1
BENCH_API_KEY=your-api-key
BENCH_MODEL=your-model

# Strong model (optional, falls back to primary)
BENCH_MODEL_STRONG=
BENCH_BASE_URL_STRONG=
BENCH_API_KEY_STRONG=

# Weak model (optional, falls back to primary)
BENCH_MODEL_WEAK=
BENCH_BASE_URL_WEAK=
BENCH_API_KEY_WEAK=

# Embedding model
BENCH_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Benchmark execution
BENCH_N_RUNS=10
BENCH_TEMPERATURE=0.7
BENCH_MAX_TOKENS=4096
BENCH_TIMEOUT=300

# Parallelism
BENCH_N_WORKERS=3

# Statistics
BENCH_P_VALUE_THRESHOLD=0.05
BENCH_MIN_SAMPLES_FOR_STATS=3
